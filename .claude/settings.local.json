{
  "permissions": {
    "allow": [
      "Bash(swift *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(git *)",
      "Bash(git init *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(which *)",
      "Bash(jq *)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(node *)",
      "Bash(npx vitest *)",
      "Bash(python3 *)",
      "Bash(bash web/*)",
      "WebSearch",
      "WebFetch",
      "Bash(exit 0)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(brew install *)",
      "Bash(git clone *)",
      "Bash(pod *)",
      "Bash(gem install *)"
    ],
    "defaultMode": "dontAsk",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/lukasbieneman/BodybuildingApp/.claude/hooks/check_rm_scope.py",
            "timeout": 10,
            "statusMessage": "Checking deletion scope"
          }
        ]
      }
    ]
  }
}
