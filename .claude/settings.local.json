{
  "permissions": {
    "allow": [
      "Bash(swift *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(git *)",
      "Bash(git init *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(which *)",
      "Bash(jq *)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm --prefix * run *)",
      "Bash(npm --prefix * test)",
      "Bash(npm --prefix * test *)",
      "Bash(node *)",
      "Bash(npx vitest *)",
      "Bash(python3 *)",
      "Bash(bash web/*)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(export *)",
      "Bash(cd *)",
      "Task",
      "WebSearch",
      "WebFetch",
      "Bash(exit 0)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm install *)",
      "Bash(npm --prefix * install*)",
      "Bash(npx *)",
      "Bash(brew install *)",
      "Bash(git clone *)",
      "Bash(pod *)",
      "Bash(gem install *)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/lukasbieneman/VSCodeProjects/BodybuildingApp/.claude/hooks/hotfire_guard.py",
            "timeout": 10,
            "statusMessage": "Hotfire guard: checking deletion scope + downloads"
          }
        ]
      }
    ]
  }
}
